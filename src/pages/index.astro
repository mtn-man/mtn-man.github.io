---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>mtn-man</h1>
			<p>
				Developer and homelab enthusiast. I build CLI tools, tinker with infrastructure,
				and write about what I learn along the way.
			</p>
			<h2>Projects</h2>
			<ul>
				<li>
					<a href="https://github.com/mtn-man/after">after</a> &mdash;
					CLI timer tool for macOS and Linux, written in Go.
				</li>
			</ul>
		</main>
		<Footer />
	</body>
</html>
